        <last-name>Чехов</last-name>
      </author>
      <book-title>Образцовый рассказ</book-title>
      <annotation>
        <p>Короткая <emphasis>аннотация</emphasis> для round-trip теста.</p>
      </annotation>
      <lang>ru</lang>
      <sequence name="Образцы" number="1"/>
      <coverpage>
        <image l:href="#cover.png"/>
      </coverpage>
    </title-info>
    <document-info>
      <id>aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee</id>
